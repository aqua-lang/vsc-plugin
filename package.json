{
    "name": "aqua",
    "displayName": "Aqua",
    "description": "Visual Studio Code support for the Aqua programming language",
    "version": "0.0.1",
    "repository": {
        "url": "https://github.com/eav-eav-eav/vsc-plugin"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "aqua",
                "aliases": [
                    "Aqua",
                    "aqua"
                ],
                "extensions": [
                    ".aqua"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/aqua-light.png",
                    "dark": "./icons/aqua-dark.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "aqua",
                "scopeName": "source.aqua",
                "path": "./syntaxes/aqua.tmLanguage.json"
            }
        ]
    },
    "author": {
        "name": "Eav",
        "url": "https://github.com/eav-eav-eav"
    }
}
