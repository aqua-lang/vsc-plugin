{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Aqua",
    "scopeName": "source.aqua",
    "patterns": [
        {
            "include": "#comments"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.documentation.aqua",
                    "match": "#!.*$"
                },
                {
                    "name": "comment.line.number-sign.aqua",
                    "match": "#.*$"
                }
            ]
        },
        "period": {
            "name": "punctuation.separator.period.aqua",
            "match": "\\."
        },
        "comma": {
            "name": "punctuation.separator.comma.aqua",
            "match": ","
        },
        "colon": {
            "name": "punctuation.separator.colon.aqua",
            "match": ":"
        },
        "double_equal": {
            "name": "punctuation.separator.equal.double.aqua",
            "match": "=="
        }
    }
}
